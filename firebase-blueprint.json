{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "A full report for a specific context (gerencia, mes, ano)",
      "type": "object",
      "properties": {
        "reportContext": {
          "type": "object",
          "description": "Context parameters of the report"
        },
        "tasks": {
          "type": "array",
          "description": "Array of work plan tasks"
        },
        "disciplines": {
          "type": "array",
          "description": "Array of management discipline comments"
        },
        "teamMembers": {
          "type": "array",
          "description": "Array of team members involved"
        },
        "insights": {
          "type": "object",
          "description": "Generated or curated report insights"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of the last update"
        }
      },
      "required": ["reportContext", "tasks", "disciplines", "teamMembers", "insights"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Collection of reports keyed by context"
    }
  }
}
